        "jsCode": "const isCrypto = (symbol) => symbol.startsWith(\"BINANCE:\");\n\nconst eligible = items.filter(item => {\n  const moveIsBig = Math.abs(item.json.dayChangePct ?? 0) >= 3;\n  return moveIsBig && !isCrypto(item.json.symbol);\n});\n\n// Sort by absolute size of move, keep only the top 4\neligible.sort((a, b) =>\n  Math.abs(b.json.dayChangePct ?? 0) - Math.abs(a.json.dayChangePct ?? 0)\n);\n\nconst top4 = eligible.slice(0, 4);\n\nconst today = new Date();\nconst from = new Date(today);\nfrom.setDate(from.getDate() - 2);\nconst fmt = (d) => d.toISOString().slice(0, 10);\n\nreturn top4.map(item => ({\n  json: {\n    ...item.json,\n    newsFrom: fmt(from),\n    newsTo: fmt(today),\n  }\n}));"
