      "parameters": {
        "jsCode": "const rows = $('compare').all().map(i => i.json);\n\nconst HOLDINGS = [\"SPY\", \"BINANCE:BTCUSDT\", \"META\"];\n\nconst SHARES = {\n  \"SPY\": 0.268072,\n  \"BINANCE:BTCUSDT\": 0.002054,\n  \"META\": 0.19012,\n};\n\nconst displayName = (s) => {\n  if (s === \"BINANCE:BTCUSDT\") return \"BTC\";\n  if (s === \"BINANCE:ETHUSDT\") return \"ETH\";\n  if (s === \"BINANCE:XRPUSDT\") return \"XRP\";\n  return s;\n};\n\nconst COMPANY_NAMES = {\n  \"NVDA\": \"Nvidia\", \"SPY\": \"S&P 500 ETF\", \"BINANCE:BTCUSDT\": \"Bitcoin\",\n  \"PLTR\": \"Palantir\", \"HOOD\": \"Robinhood\", \"TSLA\": \"Tesla\", \"ASTS\": \"AST SpaceMobile\",\n  \"MU\": \"Micron\", \"VRT\": \"Vertiv\", \"CRDO\": \"Credo Technology\", \"CCJ\": \"Cameco\",\n  \"AVGO\": \"Broadcom\", \"AMD\": \"AMD\", \"ARM\": \"Arm Holdings\",\n  \"QCOM\": \"Qualcomm\",\n  \"COIN\": \"Coinbase\", \"BINANCE:ETHUSDT\": \"Ethereum\", \"BINANCE:XRPUSDT\": \"XRP\",\n  \"AMZN\": \"Amazon\", \"TTD\": \"The Trade Desk\",\n  \"META\": \"Meta\", \"GOOGL\": \"Alphabet\", \"GLW\": \"Corning\", \"JPM\": \"JPMorgan Chase\", \"XOM\": \"ExxonMobil\",\n};\n\nconst SECTORS = {\n  \"NVDA\": \"AI Infrastructure\", \"MU\": \"AI Infrastructure\", \"VRT\": \"AI Infrastructure\",\n  \"CRDO\": \"AI Infrastructure\", \"CCJ\": \"AI Infrastructure\", \"AVGO\": \"AI Infrastructure\",\n  \"AMD\": \"AI Infrastructure\", \"ARM\": \"AI Infrastructure\", \"QCOM\": \"AI Infrastructure\",\n  \"GLW\": \"AI Infrastructure\",\n  \"PLTR\": \"Retail Momentum\", \"HOOD\": \"Retail Momentum\", \"TSLA\": \"Retail Momentum\", \"ASTS\": \"Retail Momentum\",\n  \"COIN\": \"Crypto\", \"BINANCE:ETHUSDT\": \"Crypto\", \"BINANCE:XRPUSDT\": \"Crypto\",\n  \"AMZN\": \"Mega-cap\", \"META\": \"Mega-cap\", \"GOOGL\": \"Mega-cap\",\n  \"TTD\": \"Ad Tech\",\n  \"JPM\": \"Financials\",\n  \"XOM\": \"Energy\",\n};\n\nconst SECTOR_ORDER = [\"AI Infrastructure\", \"Retail Momentum\", \"Mega-cap\", \"Financials\", \"Energy\", \"Crypto\", \"Ad Tech\"];\n\nconst fmt = (n) => n === null || n === undefined\n  ? \"n/a\"\n  : `${n >= 0 ? \"+\" : \"\"}${n.toFixed(2)}%`;\n\nconst fmtDollar = (n) =>\n  `${n >= 0 ? \"+\" : \"-\"}$${Math.abs(n).toFixed(2)}`;\n\n// Only shows anything when within 10% of the 52-week high or low — silent otherwise\nconst week52Compact = (r) => {\n  if (r.week52High == null || r.week52Low == null) return \"\";\n  const range = r.week52High - r.week52Low;\n  if (range <= 0) return \"\";\n\n  const pctFromHigh = ((r.week52High - r.price) / range) * 100;\n  if (pctFromHigh <= 10) {\n    return `  🔺 near 52wk high ($${r.week52High.toLocaleString()})`;\n  }\n\n  const pctFromLow = ((r.price - r.week52Low) / range) * 100;\n  if (pctFromLow <= 10) {\n    return `  🔻 near 52wk low ($${r.week52Low.toLocaleString()})`;\n  }\n\n  return \"\";\n};\n\n// Full version with visual gauge — used only in Holdings (short list, room to spare)\nconst week52Full = (r) => {\n  if (r.week52High == null || r.week52Low == null) return \"\";\n  const range = r.week52High - r.week52Low;\n  if (range <= 0) return \"\";\n\n  let pct = (r.price - r.week52Low) / range;\n  pct = Math.max(0, Math.min(1, pct));\n\n  const barLength = 10;\n  const pos = Math.min(barLength - 1, Math.round(pct * (barLength - 1)));\n  let bar = \"\";\n  for (let i = 0; i < barLength; i++) bar += (i === pos) ? \"🔘\" : \"─\";\n\n  const pctFromHigh = ((r.week52High - r.price) / range) * 100;\n  const pctFromLow = ((r.price - r.week52Low) / range) * 100;\n  const flag = pctFromHigh <= 10 ? \" 🔺 near high\" : (pctFromLow <= 10 ? \" 🔻 near low\" : \"\");\n\n  return `\\n   52wk: $${r.week52Low.toLocaleString()} ${bar} $${r.week52High.toLocaleString()}${flag}`;\n};\n\n// --- Narrative from the news/Claude branch ---\nlet narrative = null;\ntry {\n  const parsed = $('parse claude response').all();\n  narrative = parsed.length ? parsed[0].json : null;\n} catch (e) {\n  narrative = null;\n}\n\nconst name = (symbol) => COMPANY_NAMES[symbol] || symbol;\n\nconst watchLine = (r) => {\n  return `**${displayName(r.symbol)}** (${name(r.symbol)})  $${r.price.toLocaleString()}  |  day: ${fmt(r.dayChangePct)}${week52Compact(r)}`;\n};\n\nconst holdingLine = (r) => {\n  const shares = SHARES[r.symbol];\n  const marketValue = shares ? shares * r.price : null;\n\n  let dollarPart = \"\";\n  if (shares && r.dayChangePct !== null && r.dayChangePct !== undefined) {\n    const prevPrice = r.price / (1 + r.dayChangePct / 100);\n    const dollarChange = (r.price - prevPrice) * shares;\n    dollarPart = `  (${fmtDollar(dollarChange)} today)`;\n  }\n\n  const valuePart = marketValue ? `  —  $${marketValue.toFixed(2)} total` : \"\";\n\n  return `**${displayName(r.symbol)}** (${name(r.symbol)})  $${r.price.toLocaleString()}  |  day: ${fmt(r.dayChangePct)}${dollarPart}${valuePart}${week52Full(r)}`;\n};\n\nconst holdings = rows.filter(r => HOLDINGS.includes(r.symbol));\nconst watching = rows.filter(r => !HOLDINGS.includes(r.symbol));\n\nconst grouped = {};\nfor (const r of watching) {\n  const sector = SECTORS[r.symbol] || \"Other\";\n  if (!grouped[sector]) grouped[sector] = [];\n  grouped[sector].push(r);\n}\nfor (const sector in grouped) {\n  grouped[sector].sort((a, b) =>\n    Math.abs(b.dayChangePct ?? -Infinity) - Math.abs(a.dayChangePct ?? -Infinity)\n  );\n}\n\nconst sectorBlocks = SECTOR_ORDER\n  .filter(sector => grouped[sector])\n  .map(sector => `**${sector}**\\n${grouped[sector].map(watchLine).join(\"\\n\")}`)\n  .join(\"\\n\\n\");\n\nconst today = new Date().toLocaleDateString(\"en-US\", { month: \"long\", day: \"numeric\" });\n\n// --- MESSAGE 1: Top Stories ---\nlet message1;\nif (narrative && narrative.explanations) {\n  const rowsBySymbol = {};\n  for (const r of rows) rowsBySymbol[r.symbol] = r;\n\n  const storyLines = Object.entries(narrative.explanations).map(([symbol, explanation]) => {\n    const r = rowsBySymbol[symbol];\n    const priceLine = r\n      ? `**${displayName(symbol)}** (${name(symbol)})  $${r.price.toLocaleString()}  |  day: ${fmt(r.dayChangePct)}`\n      : `**${displayName(symbol)}** (${name(symbol)})`;\n    return `${priceLine}\\n   💬 ${explanation}`;\n  }).join(\"\\n\\n\");\n\n  message1 =\n    `📰 **Top Stories — ${today}**\\n\\n` +\n    `${narrative.summary}\\n\\n` +\n    storyLines;\n} else {\n  message1 = `📰 **Top Stories — ${today}**\\n\\nNo notable moves crossed the news threshold today.`;\n}\n\n// --- MESSAGE 2: Portfolio Digest (Holdings + full Watching) ---\nconst message2 =\n  `📊 **Daily Portfolio Digest — ${today}**\\n\\n` +\n  `💼 **Holdings**\\n${holdings.map(holdingLine).join(\"\\n\")}\\n\\n` +\n  `👀 **Watching**\\n\\n${sectorBlocks}`;\n\nreturn [\n  { json: { content: message1 } },\n  { json: { content: message2 } },\n];"
