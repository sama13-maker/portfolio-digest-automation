        "jsCode": "const fs = require('fs');\nconst DIR = '/Users/samallen/watchlist';\n\nconst dateStr = (offset) => {\n  const d = new Date();\n  d.setDate(d.getDate() - offset);\n  const year = d.getFullYear();\n  const month = String(d.getMonth() + 1).padStart(2, '0');\n  const day = String(d.getDate()).padStart(2, '0');\n  return `${year}-${month}-${day}`;\n};\n\nconst loadSnapshot = (offset) => {\n  try {\n    const raw = fs.readFileSync(`${DIR}/snapshot-${dateStr(offset)}.json`, 'utf8');\n    const map = {};\n    for (const row of JSON.parse(raw)) map[row.symbol] = row.price;\n    return map;\n  } catch (e) {\n    return null;\n  }\n};\n\nlet yesterday = null;\nfor (let o = 1; o <= 3 && !yesterday; o++) yesterday = loadSnapshot(o);\nlet lastWeek = loadSnapshot(7);\nfor (let o = 6; o <= 10 && !lastWeek; o++) lastWeek = loadSnapshot(o);\n\nconst pct = (now, prev) =>\n  (prev !== undefined && prev !== null) ? Number((((now - prev) / prev) * 100).toFixed(2)) : null;\n\nconst out = items.map(item => {\n  const prevPrice = yesterday ? yesterday[item.json.symbol] : undefined;\n  const dayPct = prevPrice !== undefined\n    ? pct(item.json.price, prevPrice)\n    : item.json.dayChangePct;\n\n  return {\n    json: {\n      symbol: item.json.symbol,\n      price: item.json.price,\n      dayChangePct: dayPct,\n      weeklyChangePct: lastWeek ? pct(item.json.price, lastWeek[item.json.symbol]) : null,\n      week52High: item.json.week52High ?? null,\n      week52Low: item.json.week52Low ?? null,\n    }\n  };\n});\n\nconst todayRows = items.map(i => ({ symbol: i.json.symbol, price: i.json.price }));\nfs.writeFileSync(`${DIR}/snapshot-${dateStr(0)}.json`, JSON.stringify(todayRows));\n\nreturn out;"
