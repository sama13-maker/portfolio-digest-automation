        "jsCode": "const grouped = {};\n\nitems.forEach((item) => {\n  const symbol = item.json.related;\n  if (!symbol) return;  // skip any article missing a ticker tag\n  if (!grouped[symbol]) grouped[symbol] = [];\n  grouped[symbol].push(item.json);\n});\n\nconst output = [];\nfor (const symbol in grouped) {\n  const sorted = grouped[symbol].sort((a, b) => b.datetime - a.datetime);\n  const top = sorted.slice(0, 2).map(a => ({ headline: a.headline, summary: a.summary }));\n  output.push({ json: { symbol, articles: top } });\n}\n\nreturn output;"
